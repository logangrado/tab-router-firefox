{
  "name": "tab-router",
  "version": "0.2.0",
  "scripts": {
    "build": "web-ext build --source-dir src --artifacts-dir .",
    "lint": "eslint src && web-ext lint --source-dir src",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "dev": "./dev.sh",
    "run": "web-ext run   --source-dir src",
    "test": "jest",
    "preversion": "node scripts/preversion.js"
  },
  "devDependencies": {
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "jest": "^30.3.0",
    "prettier": "^3.8.3",
    "web-ext": "^10.1.0"
  }
}
